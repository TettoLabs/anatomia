{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".ana/hooks/verify-context-file.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"additionalContext\": \"Sub-agent completed. If this was ana-writer, run: ana setup check [filename] --json to verify output quality.\"}'",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".ana/hooks/quality-gate.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}