{
  "name": "anatomia-cli",
  "version": "1.0.0",
  "description": "Verified AI development. Scan your project, generate context, verify every change through a four-agent pipeline.",
  "bin": {
    "ana": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "ai",
    "cli",
    "developer-tools",
    "context-engineering",
    "code-verification",
    "proof-chain",
    "pipeline",
    "claude-code",
    "code-analysis",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TettoLabs/anatomia.git",
    "directory": "packages/cli"
  },
  "homepage": "https://anatomia.dev",
  "bugs": {
    "url": "https://github.com/TettoLabs/anatomia/issues"
  },
  "author": {
    "name": "TettoLabs",
    "url": "https://anatomia.dev"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm typecheck && rm -rf dist && tsup && cp -r templates dist/",
    "dev": "tsup --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "prepublishOnly": "cp ../../README.md ./README.md && cp ../../CHANGELOG.md ./CHANGELOG.md && pnpm build && pnpm test"
  },
  "dependencies": {
    "@manypkg/get-packages": "^3.1.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "get-tsconfig": "^4.13.7",
    "glob": "^10.3.0",
    "ora": "^8.0.0",
    "web-tree-sitter": "0.25.10",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "tree-sitter-go": "0.25.0",
    "tree-sitter-javascript": "0.25.0",
    "tree-sitter-python": "0.25.0",
    "tree-sitter-typescript": "0.23.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "eslint-plugin-jsdoc": "^62.8.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
