{
  "name": "anatomia-cli",
  "version": "0.2.0",
  "description": "Verified AI development. Ship with proof.",
  "bin": {
    "ana": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "ai",
    "cli",
    "developer-tools",
    "typescript",
    "verification",
    "claude-code",
    "code-analysis",
    "ai-assistant"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TettoLabs/anatomia.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/TettoLabs/anatomia",
  "bugs": {
    "url": "https://github.com/TettoLabs/anatomia/issues"
  },
  "author": "TettoLabs",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "templates",
    "docs"
  ],
  "scripts": {
    "build": "tsup && cp -r templates dist/",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^10.3.0",
    "js-yaml": "^4.1.1",
    "ora": "^8.0.0",
    "web-tree-sitter": "0.25.10",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "tree-sitter-go": "0.25.0",
    "tree-sitter-javascript": "0.25.0",
    "tree-sitter-python": "0.25.0",
    "tree-sitter-typescript": "0.23.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "eslint-plugin-jsdoc": "^62.8.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
