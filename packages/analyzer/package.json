{
  "name": "anatomia-analyzer",
  "version": "0.1.0",
  "description": "Code analysis engine for Anatomia",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "code-analysis",
    "static-analysis",
    "tree-sitter",
    "ast-parsing",
    "framework-detection",
    "project-detection",
    "typescript",
    "python",
    "javascript",
    "golang"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TettoLabs/anatomia.git",
    "directory": "packages/analyzer"
  },
  "homepage": "https://github.com/TettoLabs/anatomia/tree/main/packages/analyzer",
  "bugs": {
    "url": "https://github.com/TettoLabs/anatomia/issues"
  },
  "author": "TettoLabs",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "docs"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "glob": "^10.3.0",
    "js-yaml": "^4.1.1",
    "tree-sitter": "0.25.0",
    "tree-sitter-go": "0.25.0",
    "tree-sitter-javascript": "0.25.0",
    "tree-sitter-python": "0.25.0",
    "tree-sitter-typescript": "0.23.2",
    "zod": "^4.3.6"
  }
}
